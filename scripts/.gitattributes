# ============================================================
# ZeroLinux - Git LFS Configuration
# ============================================================
# الملفات الكبيرة تُرفع عبر Git LFS تلقائياً

# حزم Arch Linux
*.pkg.tar.zst  filter=lfs diff=lfs merge=lfs -text
*.pkg.tar.xz   filter=lfs diff=lfs merge=lfs -text
*.pkg.tar.gz   filter=lfs diff=lfs merge=lfs -text
*.pkg.tar.bz2  filter=lfs diff=lfs merge=lfs -text

# صور ISO
*.iso          filter=lfs diff=lfs merge=lfs -text

# قواعد بيانات pacman
*.db.tar.gz    filter=lfs diff=lfs merge=lfs -text
*.files.tar.gz filter=lfs diff=lfs merge=lfs -text

# صور ثنائية كبيرة
*.squashfs     filter=lfs diff=lfs merge=lfs -text
*.img          filter=lfs diff=lfs merge=lfs -text

# ضمان نهايات الأسطر الصحيحة
*.sh   text eol=lf
*.conf text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.qml  text eol=lf
